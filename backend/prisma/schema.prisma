generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------
// 1. 관광지 마스터 테이블 (Attraction)
// ---------------------------------------------------------
model Attraction {
  id              String   @id @default(uuid())
  contentId       String?  @unique
  name            String
  address         String?
  lat             Float
  lng             Float
  imageUrl        String?
  description     String?  @db.Text
  category        String?
  phone           String?
  homepage        String?
  accessScore     Float    @default(0.5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  scores          ScoreSnapshot[]
}

// ---------------------------------------------------------
// 2. 접근성 점수 스냅샷 테이블 (ScoreSnapshot) — MK3 확장
// ---------------------------------------------------------
model ScoreSnapshot {
  id             String   @id @default(uuid())
  attractionId   String
  attraction     Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  userId         String?
  originName     String
  originLat      Float
  originLng      Float
  totalTimeMin   Int
  transferCount  Int
  walkDistanceM  Int
  waitTimeMin    Int
  finalScore     Float?   // 하위 호환 (MK2) — MK3에서는 gtt 값 저장
  gtt            Float?   // MK3 GTT 값 (분)
  grade          String?  // 'S'|'A'|'B'|'C'|'D'
  alpha          Float?   // 계산 당시 사용된 계수
  beta           Float?
  gamma          Float?
  breakdown      Json
  createdAt      DateTime @default(now())
}

// ---------------------------------------------------------
// 3. 동별 관광지 점수 캐시 테이블 (DongScore) — MK3 재설계
// 원시 시간 컴포넌트 저장 → 조회 시 프론트에서 GTT 계산
// ---------------------------------------------------------
model DongScore {
  id           String   @id @default(uuid())
  dongKey      String
  attractionId String
  tInvehicle   Float              // 순수 탑승시간 (분)
  tWalk        Float              // 도보시간 (분)
  tWait        Float              // 대기시간 (분)
  nTransfer    Int                // 환승 횟수
  hasLowFloor  Boolean  @default(false)
  dongLat      Float
  dongLng      Float
  computedAt   DateTime @default(now())

  @@unique([dongKey, attractionId])
  @@index([dongKey])
}

// ---------------------------------------------------------
// 4. AHP 설문 응답 테이블 (WeightResponse) — 역사 데이터 보존
// ---------------------------------------------------------
model WeightResponse {
  id        String   @id @default(uuid())
  a12       Float
  a13       Float
  a14       Float
  a15       Float
  a23       Float
  a24       Float
  a25       Float
  a34       Float
  a35       Float
  a45       Float
  cr        Float
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------
// 5. 사용자별 GTT 계수 저장 테이블 (UserWeight) — MK3 재설계
// ---------------------------------------------------------
model UserWeight {
  id        String   @id @default(uuid())
  userId    String   @unique
  alpha     Float    @default(2.0)   // 도보 배율
  beta      Float    @default(2.5)   // 대기 배율
  gamma     Float    @default(13.0)  // 환승 패널티 (분)
  tMax      Int      @default(0)     // 최대 이동시간 제한 (0=없음)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------
// 6. 즐겨찾기 관광지 테이블
// ---------------------------------------------------------
model FavoriteAttraction {
  id           String   @id @default(uuid())
  userId       String
  attractionId String
  createdAt    DateTime @default(now())

  @@unique([userId, attractionId])
  @@index([userId])
}

// ---------------------------------------------------------
// 7. 저장된 출발지 테이블
// ---------------------------------------------------------
model SavedRoute {
  id               String   @id @default(uuid())
  userId           String
  name             String
  originName       String
  originLat        Float
  originLng        Float
  attractionId     String
  attractionName   String
  attractionLat    Float
  attractionLng    Float
  legs             Json
  totalTimeMin     Int
  createdAt        DateTime @default(now())

  @@index([userId])
}

model SavedOrigin {
  id        String   @id @default(uuid())
  userId    String
  name      String
  lat       Float
  lng       Float
  dongKey   String?
  createdAt DateTime @default(now())

  @@index([userId])
}
